{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedDeclarations": false,
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "module": "Preserve",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true
  }
}
